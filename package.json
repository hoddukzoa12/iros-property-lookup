{
  "name": "iros-property-lookup",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,worker -c cyan,magenta \"vite\" \"wrangler dev --port 8787\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "build": "tsc --noEmit && vite build",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^3.80.0"
  }
}
